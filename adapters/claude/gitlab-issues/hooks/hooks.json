{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start-hook.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "gitlab.*issue|issue.*gitlab|list.*issue|milestone|fetch.*issue|assign.*issue|update.*issue|issue.*comment|my.*issue|open.*issue|show.*issue|create.*issue|new.*issue|add.*issue|sub.?issue|child.*issue",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/prompt-hook.sh"
          }
        ]
      }
    ]
  }
}
